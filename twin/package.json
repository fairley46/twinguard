{
  "name": "twinguard",
  "private": true,
  "version": "0.1.0",
  "description": "TwinGuard — Kubernetes-first infrastructure digital twin. Simulate before you ship.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/terraform"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "analyze": "npm --workspace @twin/api run analyze",
    "report": "npm --workspace @twin/api run report",
    "watch": "npm --workspace @twin/api run watch"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
